{
  "functions": {
    "api/claude.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/beta",
      "dest": "/beta.html"
    },
    {
      "src": "/beta.html",
      "dest": "/beta.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}